{
  "name": "boilerworks-react-native-expo",
  "version": "1.0.0",
  "description": "Expo React Native + TypeScript template with styled-components theming, Redux Toolkit + Apollo Client, React Navigation, i18next, and JWT auth with proactive refresh.",
  "license": "MIT",
  "main": "index.tsx",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "optimize-images": "yarn node scripts/optimize-images.js",
    "optimize-images:dry": "yarn node scripts/optimize-images.js --dry-run"
  },
