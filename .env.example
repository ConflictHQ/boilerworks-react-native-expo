# App Identity — used by app.config.js to set display name, bundle ID, and deep-link scheme
APP_BASE_NAME=Boilerworks
APP_BASE_SLUG=boilerworks
APP_BASE_BUNDLE_ID=com.boilerworks.app
APP_BASE_PACKAGE=com.boilerworks.app

# EAS — required for `eas build` and `eas submit`
EAS_OWNER=
EAS_PROJECT_ID=id

# API Configuration — base URL for all apiClient requests (no trailing slash)
# Local: http://localhost:3000 | Staging: https://api-staging.example.com | Prod: https://api.example.com
EXPO_PUBLIC_API_URL=http://localhost:3000

# Environment — controls IS_DEV / IS_STAGING / IS_PROD flags in src/constants/env.ts
# Also determines the deep-link scheme suffix (-dev / -staging / no suffix)
# Values: development | staging | production
EXPO_PUBLIC_ENVIRONMENT=development

# App Version (set by CI using scripts/get-version-name.sh)
# Example in CI: export APP_VERSION=$(sh scripts/get-version-name.sh prod)
APP_VERSION=1.0.0

# Build Number (optional, auto-generated from APP_VERSION if not set)
# For CI: export BUILD_NUMBER=$GITHUB_RUN_NUMBER or similar
# BUILD_NUMBER=

# Feature Flags
# EXPO_PUBLIC_ENABLE_MOCKS — when true, env.ENABLE_MOCKS is true in src/constants/env.ts
# Wire up mock API responses behind `if (env.ENABLE_MOCKS)` guards for local dev without a backend
EXPO_PUBLIC_ENABLE_MOCKS=false
# EXPO_PUBLIC_ENABLE_MOCK_LOGIN — bypass real auth and log in with mock credentials (no backend needed)
EXPO_PUBLIC_ENABLE_MOCK_LOGIN=false
# Mock credentials — only used when EXPO_PUBLIC_ENABLE_MOCK_LOGIN=true
EXPO_PUBLIC_MOCK_EMAIL=demo@example.com
EXPO_PUBLIC_MOCK_PASSWORD=password

# Analytics & Monitoring (optional) — Sentry DSN; leave empty to disable error reporting
EXPO_PUBLIC_SENTRY_DSN=

# GraphQL — Apollo Client endpoint
# Local: http://localhost:3000/graphql | Staging: https://api-staging.example.com/graphql
EXPO_PUBLIC_GRAPHQL_URL=